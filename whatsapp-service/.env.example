# Gabriel WhatsApp Service - Katabump deployment
# Upload this file as .env in whatsapp-service/ on your Katabump server.

# Katabump sets PORT automatically from the panel — do not hardcode unless required.
PORT=3000

# Lock down the service (must match WHATSAPP_SERVICE_API_KEY on the Gabriel app).
API_KEY="change-this-to-match-the-service-api-key"

# Allow your Gabriel dashboard to call this service.
ALLOWED_ORIGINS="https://gabrielagent.vercel.app,http://localhost:3000,http://127.0.0.1:3000"

# Persist WhatsApp sessions across restarts (use ./sessions on Katabump disk).
SESSION_PATH="./sessions"
SESSION_STORE="file"
LOG_LEVEL="info"

# After deploy, set on Gabriel (root .env or Vercel):
# WHATSAPP_SERVICE_URL="https://gabriel-whatsapp.kdns.fr"
# WHATSAPP_SERVICE_API_KEY="change-this-to-match-the-service-api-key"
