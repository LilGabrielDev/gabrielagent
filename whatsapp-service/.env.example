# Gabriel WhatsApp Service - Render/Katabump/Railway deployment

# Render and most hosts set PORT automatically; keep this only for local development.
PORT=3000
NODE_ENV="development"

# Public Gabriel dashboard URL. Required when NODE_ENV=production.
FRONTEND_URL="https://gabrielagent.vercel.app"

# Optional service API key for server-side proxy calls.
# Leave unset if the browser connects directly through NEXT_PUBLIC_BACKEND_URL.
API_KEY=""

# Allow your Gabriel dashboard to call this service.
ALLOWED_ORIGINS="https://gabrielagent.vercel.app,http://localhost:3000"

# Persist WhatsApp sessions across restarts.
SESSION_PATH="./sessions"
SESSION_STORE="file"
LOG_LEVEL="info"

# After deploy, set on Gabriel (root .env or Vercel):
# NEXT_PUBLIC_BACKEND_URL="https://your-whatsapp-service.onrender.com"
