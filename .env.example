# ============================================
# Owly - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# Required variables are marked with [REQUIRED]
# ============================================

# [REQUIRED] Neon pooled connection string for the app
# Copy the pooled URL from Neon. The hostname includes "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@EP-NAME-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# [REQUIRED] Neon direct connection string for Prisma CLI commands
# Copy the direct URL from Neon. The hostname does not include "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@EP-NAME.REGION.aws.neon.tech/DBNAME?sslmode=require"

# [REQUIRED] Secret key for JWT token signing (use a random 32+ char string)
JWT_SECRET="change-this-to-a-random-secret"

# [REQUIRED] App URL (used for callbacks and webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment (development | production)
NODE_ENV="development"

# ---- AI Provider ----
# OpenAI API key - required for AI-powered responses
OPENAI_API_KEY="sk-your-openai-api-key"

# ---- Phone Channel (Twilio + ElevenLabs) ----
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# ---- WhatsApp Pairing Code Service ----
# Remote pairing-code service. The service owns the WhatsApp runtime/session
# storage, so Vercel does not need to run whatsapp-web.js or Baileys.
WHATSAPP_PAIRING_CODE_ENDPOINT="https://knight-bot-paircode.onrender.com/code"

# ---- Webhook Security ----
# Secret key for HMAC-SHA256 webhook payload signatures
WEBHOOK_SECRET="change-this-to-a-random-secret"

# ---- CORS (optional) ----
# Set to allow cross-origin API access (e.g., "https://your-frontend.com")
# CORS_ORIGIN=""

# ---- Optional ----
NEXTAUTH_SECRET="change-this-to-a-random-secret"
